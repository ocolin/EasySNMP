{
    "name": "ocolin/easysnmp",
    "description": "PHP SNMP client providing formatted, DTO-backed access to standard MIB-II data without requiring SNMP knowledge",
    "type": "library",
    "keywords": [
        "snmp",
        "mib",
        "network",
        "monitoring",
        "arp",
        "interfaces",
        "php"
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4",
        "freedsx/snmp": ">=0.5.2",
        "ocolin/global-type": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "ocolin/easyenv": "^3.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ocolin\\EasySNMP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ocolin\\EasySNMP\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Colin Miller",
            "email": "ocolin@cruzio.com"
        }
    ],
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices",
        "debug": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices --debug",
        "integration": "vendor/bin/phpunit --no-coverage --group integration",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage"
    }
}
